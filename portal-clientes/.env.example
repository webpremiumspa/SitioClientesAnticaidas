# ============================================================
#  Portal de Clientes Anticaidas — variables de entorno
#  Copia este archivo como .env y complétalo en cPanel
#  (Setup Node.js App -> Environment variables).
#  NINGÚN valor secreto se versiona en git.
# ============================================================

# --- Entorno ---
NODE_ENV=development
PORT=3000
# Secreto para firmar la cookie de sesión (cadena larga y aleatoria)
SESSION_SECRET=

# --- AppSheet API (usar una app/copia de SOLO LECTURA) ---
# App ID: Manage -> Integrations -> IN -> Application id
APPSHEET_APP_ID=
# Application Access Key generada en esa misma app
APPSHEET_ACCESS_KEY=
# Nombres de tabla tal como aparecen en AppSheet
APPSHEET_TABLE_PROYECTOS=PROYECTOS
APPSHEET_TABLE_REGISTRO=REGISTRO
APPSHEET_TABLE_STATUS=STATUS
# Región del endpoint: www (global) o eu
APPSHEET_REGION=www

# --- Microsoft Graph (SharePoint) — permiso Sites.Selected, solo lectura ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Host y ruta del sitio SharePoint
SHAREPOINT_HOSTNAME=somitalspa.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/SitioclientesAnticadas
# Biblioteca de documentos (drive) donde cuelgan las carpetas de proyecto.
# Según los datos reales, la biblioteca se llama "Clientes".
SHAREPOINT_DRIVE=Clientes
# Subcarpeta de categoría activa en v1
SHAREPOINT_CATEGORIA_CERTIFICADOS=CERTIFICADOS DE INSTALACION

# --- Correo (código de un solo uso para login) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Portal Anticaidas <no-reply@anticaidas.cl>"

# --- Ejecutivo de cuenta (fijo por configuración, no está en el modelo) ---
EJECUTIVO_NOMBRE=Carlo Cofré Ramírez
EJECUTIVO_CARGO=Ejecutivo de Cuenta · Jefe de Operaciones
EJECUTIVO_EMAIL=ccofre@anticaidas.cl
EJECUTIVO_TELEFONO=+56 2 2226 7461
EJECUTIVO_MOVIL=+56 9 7642 1108

# --- Sincronización / caché ---
# Directorio del store local. SEGURIDAD: debe estar FUERA del docroot web
# (si no, portal.json con datos de clientes sería descargable). Ej. en cPanel:
DATA_DIR=/home/somitalc/portal-data
# Cada cuántos minutos el backend refresca datos desde AppSheet
SYNC_INTERVAL_MIN=10
# Minutos de validez del código OTP
OTP_TTL_MIN=10

# --- Solo pruebas ---
# Si se define, TODOS los códigos OTP se envían a esta dirección (para probar
# el login sin molestar a clientes reales). Dejar VACÍO en producción.
OTP_TEST_EMAIL=

# --- Modo demo ---
# true = usa datos de ejemplo embebidos (no llama a AppSheet ni Graph).
# Útil para desarrollo local sin credenciales. En producción: false.
DEMO_MODE=true
